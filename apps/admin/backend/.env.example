# Mindforge Admin Backend — PostgreSQL
# Copy to .env and fill in your values

# Option 1: Full connection URL
# DATABASE_URL=postgresql://user:password@host:5432/mindforge_admin

# Option 2: Individual vars
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=mindforge
DB_PASSWORD=your_password
DB_NAME=mindforge_admin

# Server
ADMIN_SERVICE_PORT=3004
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5176,http://localhost:3000
