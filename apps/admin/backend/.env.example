# Mindforge Admin Backend — PostgreSQL
# Copy to .env and fill in your values

# Option 1: Connection URL
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mindforge_admin

# Option 2: Individual vars
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=mindforge_admin

# Server
ADMIN_SERVICE_PORT=3004
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5176,http://localhost:3000,http://10.0.2.2:8081
