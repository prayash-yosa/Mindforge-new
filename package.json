{
  "name": "mindforge",
  "version": "1.0.0",
  "private": true,
  "description": "Mindforge — Multi-application education platform (Student, Parent, Teacher, Admin)",
  "workspaces": [
    "apps/*/frontend",
    "apps/*/backend",
    "apps/mobile",
    "services/*",
    "shared"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.0.0"
}
